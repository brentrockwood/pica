FROM node:22-bookworm AS node

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

COPY --from=node /usr/local /usr/local

RUN apt-get update \
	&& apt-get install -y --no-install-recommends ca-certificates git libcairo2-dev libpango1.0-dev libjpeg-dev libgif-dev librsvg2-dev fd-find ripgrep \
	&& ln -s "$(command -v fdfind)" /usr/local/bin/fd \
	&& useradd --create-home node \
	&& rm -rf /var/lib/apt/lists/*

WORKDIR /workspace-base
RUN chown node:node /workspace-base && mkdir /workspace && chown node:node /workspace
COPY --chown=node:node . .
USER node

RUN npm ci --ignore-scripts
